GIT_PS1_SHOWCOLORHINTS=true

PS1='\e[0;32m\@\e[m \[\e[0;36m\]\u\[\e[0;36m\]@\[\e[0;36m\]\h\[\e[0;36m\]:\[\e[0;34m\]\w\[\e[0;39m\]\[\e[0;31m\]$(__git_ps1 " (%s)")\[\e[0;31m\] \[\e[1;39m\]\n\$ '

# . "/home/katzda/.local/share/lscolors.sh";

